#!/bin/sh
# Decrypt the chezmoi age identity on first apply so encrypted files can
# be applied. Prompts once for the passphrase (backed up in Proton Pass).
set -eu

if [ ! -f "$HOME/.config/chezmoi/key.txt" ]; then
    mkdir -p "$HOME/.config/chezmoi"
    # $CHEZMOI_EXECUTABLE, not bare chezmoi: during `setup` bootstrap the
    # binary runs from ./bin and isn't on PATH yet
    "$CHEZMOI_EXECUTABLE" age decrypt --passphrase --output "$HOME/.config/chezmoi/key.txt" "{{ .chezmoi.sourceDir }}/key.txt.age"
    chmod 600 "$HOME/.config/chezmoi/key.txt"
fi
