#!/bin/bash
set -euo pipefail

# terminfo hash: {{ include "ghostty.terminfo" | sha256sum }}

# Ghostty sets TERM=xterm-ghostty, but containers (devpod) usually lack
# that terminfo entry, which breaks zle redrawing (doubled/overlapping
# characters while typing). Compile it into ~/.terminfo, which ncurses
# checks before the system database.
#
# Run unconditionally: this script only fires when the terminfo blob's hash
# (above) changes, and `tic -o` is an idempotent overwrite. Gating on
# `infocmp` instead skipped the recompile whenever *any* xterm-ghostty entry
# already existed, so an updated terminfo never landed.
tic -x -o "$HOME/.terminfo" "{{ .chezmoi.sourceDir }}/ghostty.terminfo"
