#!/bin/sh
# Unlock the dotfiles' age-encrypted secrets: the identity itself, then
# the SSH signing key and sops age keys it protects. The identity is
# passphrase-protected (backed up in Proton Pass) and can only be
# unlocked with a real controlling TTY, which non-interactive apply runs
# (e.g. `devpod up`) don't have. This is a plain script, not run_once:
# it re-runs on every apply and is a fast no-op once everything is
# unlocked, so a later `chezmoi apply` from an interactive shell finishes
# what a non-interactive one had to skip.
set -eu

key="$HOME/.config/chezmoi/key.txt"

if [ ! -f "$key" ]; then
    # /dev/tty may exist but be unopenable (no controlling terminal).
    # Test with a real open; use `true` not `exec`/`:` because redirection
    # failures on special builtins abort dash entirely.
    if { true </dev/tty; } 2>/dev/null; then
        mkdir -p "$HOME/.config/chezmoi"
        echo "Unlocking the age key that decrypts the repo's secrets (sops key," >&2
        echo "git signing key). The passphrase is backed up in Proton Pass." >&2
        # $CHEZMOI_EXECUTABLE, not bare chezmoi: during `setup` bootstrap the
        # binary runs from ./bin and isn't on PATH yet
        "$CHEZMOI_EXECUTABLE" age decrypt --passphrase --output "$key" "{{ .chezmoi.sourceDir }}/key.txt.age"
        chmod 600 "$key"
    else
        echo "No usable TTY, skipping age key decryption." >&2
        echo "Run 'chezmoi apply' from an interactive shell to unlock secrets." >&2
    fi
fi

if [ -f "$key" ]; then
    # `chezmoi age decrypt` (without --passphrase) only supports
    # passphrase-protected files, not identity-based decryption, so use
    # the `decrypt` template function instead: it reads the configured
    # [age] identity (this same key.txt) and needs no passphrase or tty.
    # --source is explicit (not inherited) because `include` resolves
    # relative to it: a caller that overrides --source for the outer
    # apply (e.g. CI, testing against a checkout) would otherwise leave
    # this child invocation falling back to the default source dir.
    signing_key="$HOME/.ssh/id_ed25519_signing"
    if [ ! -f "$signing_key" ]; then
        mkdir -p "$HOME/.ssh"
        chmod 700 "$HOME/.ssh"
        "$CHEZMOI_EXECUTABLE" execute-template --source "{{ .chezmoi.sourceDir }}" --output "$signing_key" \
            '{{"{{"}} decrypt (include "private_dot_ssh/private_id_ed25519_signing.age") {{"}}"}}'
        chmod 600 "$signing_key"
    fi

    sops_keys="$HOME/.config/sops/age/keys.txt"
    if [ ! -f "$sops_keys" ]; then
        mkdir -p "$HOME/.config/sops/age"
        chmod 700 "$HOME/.config/sops/age"
        "$CHEZMOI_EXECUTABLE" execute-template --source "{{ .chezmoi.sourceDir }}" --output "$sops_keys" \
            '{{"{{"}} decrypt (include "dot_config/private_sops/private_age/private_keys.txt.age") {{"}}"}}'
        chmod 600 "$sops_keys"
    fi
fi
