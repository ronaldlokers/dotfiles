#!/bin/sh
# Unlock the dotfiles' age-encrypted secrets: the identity itself, then
# the SSH signing key, sops age keys, and gh token it protects. The
# identity is passphrase-protected (backed up in Proton Pass) and can only
# be unlocked with a real controlling TTY, which non-interactive apply runs
# (e.g. `devpod up`) don't have. This is a plain script, not run_once: it
# re-runs on every apply and is a fast no-op once everything is unlocked, so
# a later `chezmoi apply` from an interactive shell finishes what a
# non-interactive one had to skip.
#
# Each secret is re-derived when it's missing/empty OR when its source blob
# has changed since last time (rotation): a per-secret marker under
# $secrets_state records the sha256 of the .age source that produced the
# current plaintext. Decryption is atomic (temp file + validate non-empty +
# mv) so a wrong passphrase or interrupted run never leaves a zero-byte
# "poison" file that later runs would trust and skip forever.
set -eu

secrets_state="$HOME/.local/state/chezmoi-dotfiles/secrets"

# secret_current TARGET WANT_HASH -> true if TARGET is up to date.
# Up to date = non-empty AND (no marker yet — a legacy/first run, so trust the
# existing file and backfill the marker) OR the marker matches WANT_HASH.
secret_current() {
    [ -s "$1" ] || return 1
    _marker="$secrets_state/$(basename "$1").sha"
    [ -f "$_marker" ] || { secret_mark "$1" "$2"; return 0; }
    [ "$(cat "$_marker")" = "$2" ]
}

secret_mark() {
    mkdir -p "$secrets_state"
    printf '%s\n' "$2" > "$secrets_state/$(basename "$1").sha"
}

# decrypt_to TARGET TEMPLATE WANT_HASH: render TEMPLATE (an identity-based
# decrypt-of-include expression) to a temp file, and only promote it to TARGET
# if it succeeds and is non-empty; then record the source hash.
decrypt_to() {
    _tmp="$(mktemp)"
    # $CHEZMOI_EXECUTABLE, not bare chezmoi: during `setup` bootstrap the
    # binary runs from ./bin and isn't on PATH yet. --source is explicit (not
    # inherited) because `include` resolves relative to it.
    if "$CHEZMOI_EXECUTABLE" execute-template --source "{{ .chezmoi.sourceDir }}" --output "$_tmp" "$2" && [ -s "$_tmp" ]; then
        mv "$_tmp" "$1"
        chmod 600 "$1"
        secret_mark "$1" "$3"
    else
        rm -f "$_tmp"
        echo "error: failed to decrypt $1 (wrong age identity or corrupt blob)" >&2
        exit 1
    fi
}

key="$HOME/.config/chezmoi/key.txt"
key_hash='{{ include "key.txt.age" | sha256sum }}'

if ! secret_current "$key" "$key_hash"; then
    # /dev/tty may exist but be unopenable (no controlling terminal).
    # Test with a real open; use `true` not `exec`/`:` because redirection
    # failures on special builtins abort dash entirely.
    if { true </dev/tty; } 2>/dev/null; then
        mkdir -p "$HOME/.config/chezmoi"
        echo "Unlocking the age key that decrypts the repo's secrets (sops key," >&2
        echo "git signing key). The passphrase is backed up in Proton Pass." >&2
        _tmp="$(mktemp)"
        if "$CHEZMOI_EXECUTABLE" age decrypt --passphrase --output "$_tmp" "{{ .chezmoi.sourceDir }}/key.txt.age" && [ -s "$_tmp" ]; then
            mv "$_tmp" "$key"
            chmod 600 "$key"
            secret_mark "$key" "$key_hash"
        else
            rm -f "$_tmp"
            echo "error: failed to unlock the age identity (wrong passphrase?)" >&2
            exit 1
        fi
    else
        echo "No usable TTY, skipping age key decryption." >&2
        echo "Run 'chezmoi apply' from an interactive shell to unlock secrets." >&2
    fi
fi

if [ -f "$key" ]; then
    # `chezmoi age decrypt` (without --passphrase) only supports
    # passphrase-protected files, not identity-based decryption, so use the
    # `decrypt` template function instead: it reads the configured [age]
    # identity (this same key.txt) and needs no passphrase or tty.
    signing_key="$HOME/.ssh/id_ed25519_signing"
    signing_hash='{{ include "private_dot_ssh/private_id_ed25519_signing.age" | sha256sum }}'
    if ! secret_current "$signing_key" "$signing_hash"; then
        mkdir -p "$HOME/.ssh"
        chmod 700 "$HOME/.ssh"
        decrypt_to "$signing_key" '{{"{{"}} decrypt (include "private_dot_ssh/private_id_ed25519_signing.age") {{"}}"}}' "$signing_hash"
    fi

    sops_keys="$HOME/.config/sops/age/keys.txt"
    sops_hash='{{ include "dot_config/private_sops/private_age/private_keys.txt.age" | sha256sum }}'
    if ! secret_current "$sops_keys" "$sops_hash"; then
        mkdir -p "$HOME/.config/sops/age"
        chmod 700 "$HOME/.config/sops/age"
        decrypt_to "$sops_keys" '{{"{{"}} decrypt (include "dot_config/private_sops/private_age/private_keys.txt.age") {{"}}"}}' "$sops_hash"
    fi

    gh_hosts="$HOME/.config/gh/hosts.yml"
    gh_hash='{{ include "dot_config/gh/private_hosts.yml.age" | sha256sum }}'
    if ! secret_current "$gh_hosts" "$gh_hash"; then
        mkdir -p "$HOME/.config/gh"
        chmod 700 "$HOME/.config/gh"
        decrypt_to "$gh_hosts" '{{"{{"}} decrypt (include "dot_config/gh/private_hosts.yml.age") {{"}}"}}' "$gh_hash"
    fi
fi
