{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "mise": {
    "managerFilePatterns": [
      "/(^|/)dot_config/mise/config\\.toml$/"
    ]
  },
  "customManagers": [
    {
      "description": "Bump tag-pinned .chezmoiexternals archives via inline `# renovate:` annotations",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.chezmoiexternals/.*\\.toml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)[\\s\\S]*?:= \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Bump the pinned mise binary version in the external",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.chezmoiexternals/mise\\.toml$/"
      ],
      "matchStrings": [
        "\\$miseVersion := \"(?<currentValue>v[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "jdx/mise"
    },
    {
      "description": "Track the pinned pomo git tag (mise's pipx git backend isn't covered by the mise manager)",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)dot_config/mise/config\\.toml$/"
      ],
      "matchStrings": [
        "mischavandenburg/pomo\\.git\"\\s*=\\s*\\{\\s*version\\s*=\\s*\"(?<currentValue>v[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "mischavandenburg/pomo"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge patch/minor once CI is green; majors wait for review",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
