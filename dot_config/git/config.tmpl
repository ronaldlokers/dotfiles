# Managed by chezmoi. Truly machine-local settings (identity overrides,
# host-specific credential helpers) belong in ~/.gitconfig, which git reads
# after this file and which chezmoi leaves alone. The gh credential helper
# below is portable — gh is installed on every machine via mise — so it lives
# here: it lets HTTPS pushes to github.com authenticate with the gh token
# (e.g. inside devcontainers where the SSH agent isn't forwarded). SSH
# remotes ignore it, so it doesn't affect the normal ssh git_protocol flow.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[user]
	name = Ronald Lokers
	email = {{ .email }}
	signingkey = ~/.ssh/id_ed25519_signing.pub
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[rerere]
	enabled = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	syntax-theme = Catppuccin Mocha
[alias]
	st = status --short --branch
	lg = log --oneline --graph --decorate
	amend = commit --amend --no-edit
