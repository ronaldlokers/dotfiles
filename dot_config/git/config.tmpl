# Managed by chezmoi. Machine-local settings (credential helpers,
# identity overrides) belong in ~/.gitconfig, which git reads after
# this file and which chezmoi leaves alone.
[user]
	name = Ronald Lokers
	email = {{ .email }}
	signingkey = ~/.ssh/id_ed25519_signing.pub
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[rerere]
	enabled = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[alias]
	st = status --short --branch
	lg = log --oneline --graph --decorate
	amend = commit --amend --no-edit
