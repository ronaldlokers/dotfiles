# ~~~~~~~~~~~~~~~ Environment Variables ~~~~~~~~~~~~~~~~~~~~~~~~


if command -v nvim > /dev/null ; then
  export EDITOR="nvim"
  export VISUAL="nvim"
fi

export LANG="en_US.UTF-8"

export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"

# Keep SSH_AUTH_SOCK pointing at a *live* agent — shared logic, also
# sourced by dot_bashrc. See ~/.config/shell/ssh-agent.sh.
[ -r "$HOME/.config/shell/ssh-agent.sh" ] && . "$HOME/.config/shell/ssh-agent.sh"


# ~~~~~~~~~~~~~~~ Mise ~~~~~~~~~~~~~~~~~~~~~~~~


if [ -x "$HOME/.local/bin/mise" ]; then
  eval "$($HOME/.local/bin/mise activate zsh)"
elif command -v mise > /dev/null ; then
  eval "$(mise activate zsh)"
fi

if command -v direnv > /dev/null ; then
  eval "$(direnv hook zsh)"
fi


# ~~~~~~~~~~~~~~~ Completion setup ~~~~~~~~~~~~~~~~~~~~~~~~


# fpath must be complete before compinit runs — either ours below or
# the one inside omarchy's zoptions

# pure is a chezmoi external, present on every OS
fpath+=("$HOME/.zsh/pure")

# Generated completions are cached as files in fpath; regenerating them
# with `source <(...)` on every shell start is slow. Delete a file to
# refresh it after a tool update.
mkdir -p "$HOME/.zsh/completions"
fpath+=("$HOME/.zsh/completions")

for cmd in mise kubectl; do
  # regenerate when the cache is missing *or empty*: a previous run that wrote
  # the file before the generator failed would leave a zero-byte `_cmd` that a
  # plain `[ -f ]` guard then trusts forever, poisoning fpath. Write to a temp
  # file and only promote it if the generator succeeded and produced output.
  if command -v "$cmd" > /dev/null && [ ! -s "$HOME/.zsh/completions/_$cmd" ]; then
    if "$cmd" completion zsh > "$HOME/.zsh/completions/_$cmd.tmp" 2>/dev/null &&
       [ -s "$HOME/.zsh/completions/_$cmd.tmp" ]; then
      mv "$HOME/.zsh/completions/_$cmd.tmp" "$HOME/.zsh/completions/_$cmd"
    else
      rm -f "$HOME/.zsh/completions/_$cmd.tmp"
    fi
  fi
done


# ~~~~~~~~~~~~~~~ Omarchy ~~~~~~~~~~~~~~~~~~~~~~~~


# On Omarchy machines the omarchy-zsh package ships shared shell config
# under /usr/share; source it from there so it coexists with this file.
# Never run omarchy-setup-zsh — it *replaces* ~/.zshrc and ~/.bashrc,
# which chezmoi owns. zoptions sets options, runs compinit and loads
# autosuggestions + syntax-highlighting; envs/aliases/functions add
# omarchy's aliases and helpers (tdl, format-drive, ...). shell/inits
# is deliberately skipped: mise, fzf and zoxide are set up in this file
# already, and the prompt is pure, not starship. Everything below this
# block wins where the two disagree (vi-mode, history size, ls/v).
if [ -r /usr/share/omarchy-zsh/shell/zoptions ]; then
  source /usr/share/omarchy-zsh/shell/zoptions
  source /usr/share/omarchy-zsh/shell/envs
  source /usr/share/omarchy-zsh/shell/aliases
  source /usr/share/omarchy-zsh/shell/functions
  _omarchy_zsh=1
fi


# ~~~~~~~~~~~~~~~ Completion ~~~~~~~~~~~~~~~~~~~~~~~~


# compinit's full security audit is slow; skip it (-C) unless the dump
# is older than a day. Omarchy's zoptions already ran compinit.
if [ -z "${_omarchy_zsh:-}" ]; then
  autoload -Uz compinit
  if [ -n "$(find "$HOME/.zcompdump" -mmin -1440 2>/dev/null)" ]; then
    compinit -C
  else
    compinit
  fi
fi

if command -v fzf > /dev/null ; then
  source <(fzf --zsh)

  if command -v fd > /dev/null ; then
    export FZF_DEFAULT_COMMAND="fd --type f --hidden --exclude .git"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="fd --type d --hidden --exclude .git"
  fi

  if command -v bat > /dev/null ; then
    export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
  fi
fi

# zoxide wants to run after compinit; omarchy's cd->zd alias needs its
# `z` function too
if command -v zoxide > /dev/null ; then
  eval "$(zoxide init zsh)"
fi


# ~~~~~~~~~~~~~~~ History ~~~~~~~~~~~~~~~~~~~~~~~~


# after the omarchy block so these sizes win over its 32768
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

setopt share_history      # share history between all shells (tmux panes)
setopt hist_ignore_dups   # don't record consecutive duplicates
setopt hist_ignore_space  # don't record commands starting with a space


# ~~~~~~~~~~~~~~~ Prompt ~~~~~~~~~~~~~~~~~~~~~~~~


PURE_GIT_PULL=0

autoload -U promptinit; promptinit

prompt pure


# enable zsh vi-mode; overrides omarchy's bindkey -e (its extra widget
# bindings live in the emacs keymap and stay dormant under vi-mode)
bindkey -v
export KEYTIMEOUT=1 # make switching between modes faster


# ~~~~~~~~~~~~~~~ Aliases ~~~~~~~~~~~~~~~~~~~~~~~~


# defined after omarchy's so ls/v here win over its eza/vim

if command -v nvim > /dev/null ; then
  alias v="nvim"
fi

if command -v git > /dev/null ; then
  alias gp="git pull"
fi

if command -v lazygit > /dev/null ; then
  alias lg="lazygit"
fi

if command -v kubectl > /dev/null ; then
  alias k="kubectl"
fi

if command -v bat > /dev/null ; then
  alias cat="bat"
fi

if command -v lsd > /dev/null ; then
  alias ls="lsd"
  alias ll="ls -lgh"
  alias la='ls -lathr'
  alias lla='ls -lgha'
  alias lt='ls --tree'
fi


# ~~~~~~~~~~~~~~~ Plugins ~~~~~~~~~~~~~~~~~~~~~~~~


# fzf-tab wants to load after compinit but before widget-wrapping
# plugins like zsh-autosuggestions (which only wraps at the first
# prompt, so loading here is early enough even when omarchy already
# sourced it). MENU_COMPLETE (set by omarchy) bypasses fzf-tab's menu,
# so turn it off.
if command -v fzf > /dev/null && [ -f "$HOME/.zsh/fzf-tab/fzf-tab.plugin.zsh" ]; then
  unsetopt menu_complete
  zstyle ':completion:*' menu no
  source "$HOME/.zsh/fzf-tab/fzf-tab.plugin.zsh"
fi

# omarchy's zoptions already loads the system copies of these two;
# only source the chezmoi-external copies when it didn't
if ! typeset -f _zsh_autosuggest_start > /dev/null \
    && [ -f "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
  source "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# syntax highlighting wants to be sourced last
if [ -z "${ZSH_HIGHLIGHT_VERSION:-}" ] \
    && [ -f "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
  source "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

unset _omarchy_zsh
